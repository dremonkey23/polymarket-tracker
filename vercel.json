{
  "version": 2,
  "builds": [
    {
      "src": "server/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server/index.js"
    },
    {
      "src": "/",
      "dest": "/public/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    }
  ],
  "env": {
    "DEMO_MODE": "true",
    "DB_PATH": "/tmp/polysights.db",
    "PYTHON_PATH": "node",
    "SCRAPER_PATH": "./server/scripts/sanitized-scraper.js",
    "REFRESH_INTERVAL_MS": "900000"
  }
}